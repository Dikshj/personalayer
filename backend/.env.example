PERSONALAYER_ENV=development
PERSONALAYER_LOCAL_AUTH=1
PERSONALAYER_LOCAL_AUTH_BOOTSTRAP_TOKEN=
PERSONALAYER_ALLOWED_ORIGINS=http://127.0.0.1:7823,http://localhost:7823
PERSONALAYER_EXTENSION_ORIGINS=
PERSONALAYER_COOKIE_SECURE=0
PERSONALAYER_MAX_REQUEST_BYTES=1048576
PERSONALAYER_DEV_MODE=0

# Optional upstream proxy key. Leave unset unless you intentionally proxy chat calls.
OPENAI_API_KEY=

# GitHub: auto-syncs every 6h when backend starts
GITHUB_USERNAME=your_github_username

# Optional: GitHub token raises rate limit 60 → 5000 req/hr
# Get one: github.com/settings/tokens (read:user scope only)
GITHUB_TOKEN=

# Connector OAuth clients for live agent fetchers
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
NOTION_OAUTH_CLIENT_ID=
NOTION_OAUTH_CLIENT_SECRET=
SPOTIFY_OAUTH_CLIENT_ID=
SPOTIFY_OAUTH_CLIENT_SECRET=
SLACK_OAUTH_CLIENT_ID=
SLACK_OAUTH_CLIENT_SECRET=
LINEAR_OAUTH_CLIENT_ID=
LINEAR_OAUTH_CLIENT_SECRET=
JIRA_OAUTH_CLIENT_ID=
JIRA_OAUTH_CLIENT_SECRET=
TODOIST_OAUTH_CLIENT_ID=
TODOIST_OAUTH_CLIENT_SECRET=
STRAVA_OAUTH_CLIENT_ID=
STRAVA_OAUTH_CLIENT_SECRET=
REDDIT_OAUTH_CLIENT_ID=
REDDIT_OAUTH_CLIENT_SECRET=
FIGMA_OAUTH_CLIENT_ID=
FIGMA_OAUTH_CLIENT_SECRET=
DROPBOX_OAUTH_CLIENT_ID=
DROPBOX_OAUTH_CLIENT_SECRET=
MICROSOFT_OAUTH_CLIENT_ID=
MICROSOFT_OAUTH_CLIENT_SECRET=
TRELLO_OAUTH_CLIENT_ID=
TRELLO_OAUTH_CLIENT_SECRET=
ASANA_OAUTH_CLIENT_ID=
ASANA_OAUTH_CLIENT_SECRET=
