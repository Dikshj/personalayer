# Local prototype
PERSONALAYER_ENABLED_COLLECTORS=
PERSONALAYER_DISABLED_COLLECTORS=
PERSONALAYER_GITHUB_USERNAME=

# Optional upstream model proxy. Keep empty for local dry-run behavior.
OPENAI_API_KEY=
OPENAI_BASE_URL=

# Connector OAuth client ids for local authorization URL generation.
# Provider token exchange should be implemented in native/on-device targets.
GOOGLE_OAUTH_CLIENT_ID=
NOTION_OAUTH_CLIENT_ID=
SPOTIFY_OAUTH_CLIENT_ID=
YOUTUBE_OAUTH_CLIENT_ID=

# Thin cloud deployment. Do not put user behavior, context bundles, graph data,
# temporal chains, embeddings, or synthesized attributes in Supabase.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# APNs routing only. Notification payloads must contain route metadata, not
# behavioral-derived text or daily insight content.
APNS_TEAM_ID=
APNS_KEY_ID=
APNS_BUNDLE_ID=
APNS_AUTH_KEY_PATH=
