# PersonaLayer frontend environment variables.
# Copy to .env.local for local dev, and set these in Netlify for production.

# Base URL of the deployed PersonaLayer backend API.
VITE_PERSONALAYER_API_BASE=https://personalayer.onrender.com

# Require a signed-in session before showing /app/* (1/true to require).
VITE_PERSONALAYER_REQUIRE_SESSION=1

# Supabase project URL (Project Settings → API → Project URL).
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase public anon key (Project Settings → API → anon public).
# Use ONLY the anon key here. Never put the service role key or JWT secret
# in the frontend — those belong on the backend.
VITE_SUPABASE_ANON_KEY=your-supabase-anon-public-key
